# ─── HOCS Till Middleware — Environment Variables ────────────────────────────
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# Server
PORT=3000
NODE_ENV=development

# ─── Till Payments (PayNuts) ─────────────────────────────────────────────────
# Sandbox: https://test-gateway.tillpayments.com
# Production: https://gateway.tillpayments.com
TILL_BASE_URL=https://test-gateway.tillpayments.com
TILL_API_KEY=your-api-key-here
TILL_SHARED_SECRET=your-shared-secret-here
TILL_API_USER=your-api-user-here
TILL_API_PASS=your-api-password-here
# NOTE: TILL_API_PASS was NOT included in the PayNuts onboarding docs.
# Retrieve it from the Till Payments merchant dashboard or contact Till support.

# ─── Shopify Custom App (2026 Dev Dashboard — Client Credentials Grant) ─────
SHOPIFY_STORE_DOMAIN=highonchapel.myshopify.com
SHOPIFY_CLIENT_ID=your-client-id-here
SHOPIFY_CLIENT_SECRET=your-client-secret-here
SHOPIFY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ─── SMTP (Payment Link Emails) ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=High on Chapel <noreply@highonchapel.com>

# ─── Store URL ───────────────────────────────────────────────────────────────
STORE_URL=https://highonchapel.com

# ─── URLs ────────────────────────────────────────────────────────────────────
# CALLBACK_URL must be the public URL of this middleware + /api/till-callback
CALLBACK_URL=https://your-middleware-domain.com/api/till-callback
SUCCESS_URL=https://highonchapel.com/pages/payment-success
CANCEL_URL=https://highonchapel.com/pages/payment-cancelled
ERROR_URL=https://highonchapel.com/pages/payment-error

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite file path — persists transactions across server restarts
# Default: ./hocs-middleware.db (relative to middleware folder)
DB_PATH=./hocs-middleware.db
